{
  "name": "video-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:build-ts": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"next dev --turbopack --port 3003\" \"wait-on http://localhost:3003 && cross-env DEV_PORT=3003 electron dist-electron/main.js\"",
    "electron:build": "cross-env BUILD_TARGET=electron next build && npm run electron:build-ts",
    "electron:pack": "npm run electron:build && electron-builder --win",
    "electron:start": "electron dist-electron/main.js"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@gsap/react": "^2.1.2",
    "@huggingface/transformers": "^3.8.1",
    "@mediapipe/tasks-vision": "^0.10.32",
    "gsap": "^3.14.2",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0",
    "webm-muxer": "^5.1.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
